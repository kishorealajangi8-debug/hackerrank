import java.util.Scanner;

public class Solution {
    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        int t = in.nextInt(); // Number of queries
        
        for (int i = 0; i < t; i++) {
            int a = in.nextInt();
            int b = in.nextInt();
            int n = in.nextInt();
            
            int currentSum = a;
            for (int j = 0; j < n; j++) {
                // Math.pow returns a double, so we cast to int
                // Or simply keep a multiplier that doubles each time
                currentSum += (int)Math.pow(2, j) * b;
                System.out.print(currentSum + " ");
            }
            // Print a newline after each query series
            System.out.println();
        }
        in.close();
    }
}
