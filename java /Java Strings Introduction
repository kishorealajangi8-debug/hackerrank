import java.util.Scanner;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String A = sc.next();
        String B = sc.next();
        sc.close();

        // 1. Sum the lengths
        System.out.println(A.length() + B.length());

        // 2. Lexicographical comparison
        // compareTo returns > 0 if A comes after B
        if (A.compareTo(B) > 0) {
            System.out.println("Yes");
        } else {
            System.out.println("No");
        }

        // 3. Capitalization
        // Grab the first letter, upper case it, then attach the rest of the string
        String capitalizeA = A.substring(0, 1).toUpperCase() + A.substring(1);
        String capitalizeB = B.substring(0, 1).toUpperCase() + B.substring(1);
        
        System.out.println(capitalizeA + " " + capitalizeB);
    }
}
