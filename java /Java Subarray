import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int[] a = new int[n];
        
        for (int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }
        sc.close();
        
        int negativeSubarrays = 0;
        
        // Outer loop: starting index of the subarray
        for (int i = 0; i < n; i++) {
            int currentSum = 0;
            
            // Inner loop: ending index of the subarray
            for (int j = i; j < n; j++) {
                // Add the current element to the running sum of the subarray [i...j]
                currentSum += a[j];
                
                // If the sum is negative, increment our counter
                if (currentSum < 0) {
                    negativeSubarrays++;
                }
            }
        }
        
        System.out.println(negativeSubarrays);
    }
}
