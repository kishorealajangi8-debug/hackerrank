import java.util.*;

public class Solution {

    public static boolean canWin(int leap, int[] game, int i) {
        // Base Case: Won the game
        if (i >= game.length) {
            return true;
        }
        // Base Case: Out of bounds or hit a 1 (blocked or already visited)
        if (i < 0 || game[i] == 1) {
            return false;
        }

        // Mark this cell as visited by changing 0 to 1
        game[i] = 1;

        // Recursive Calls: Try all 3 possible moves
        // If ANY of them lead to a win, return true
        return canWin(leap, game, i + leap) || 
               canWin(leap, game, i + 1) || 
               canWin(leap, game, i - 1);
    }

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        int q = scan.nextInt();
        while (q-- > 0) {
            int n = scan.nextInt();
            int leap = scan.nextInt();
            
            int[] game = new int[n];
            for (int i = 0; i < n; i++) {
                game[i] = scan.nextInt();
            }

            System.out.println(canWin(leap, game, 0) ? "YES" : "NO");
        }
        scan.close();
    }
}
